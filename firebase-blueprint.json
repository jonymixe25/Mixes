{
  "entities": {
    "NewsItem": {
      "title": "NewsItem",
      "description": "A news article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" }
      },
      "required": ["title", "content", "author", "date"]
    },
    "CommunityVideo": {
      "title": "CommunityVideo",
      "description": "A community video",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "authorUid": { "type": "string" },
        "thumbnail": { "type": "string" },
        "price": { "type": "string" },
        "video_url": { "type": "string" },
        "published": { "type": "boolean" }
      },
      "required": ["title", "author", "authorUid", "thumbnail", "price", "video_url", "published"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "A team member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "icon": { "type": "string" },
        "linkedin": { "type": "string" },
        "twitter": { "type": "string" },
        "github": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["name", "role", "bio", "image", "icon"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["admin", "user"] },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["role", "email"]
    },
    "MediaItem": {
      "title": "MediaItem",
      "description": "A photo or video post",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["image", "video"] },
        "url": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["type", "url", "authorUid", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a media item",
      "type": "object",
      "properties": {
        "mediaId": { "type": "string" },
        "text": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["mediaId", "text", "authorUid", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact relationship between users",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "initiatedBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["users", "status", "initiatedBy"]
    },
    "ChatGroup": {
      "title": "ChatGroup",
      "description": "A group for chat and video calls",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" }
      },
      "required": ["name", "members", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "news": {
      "schema": { "$ref": "#/entities/NewsItem" },
      "description": "News articles"
    },
    "community_videos": {
      "schema": { "$ref": "#/entities/CommunityVideo" },
      "description": "Community videos"
    },
    "team": {
      "schema": { "$ref": "#/entities/TeamMember" },
      "description": "Team members"
    },
    "users": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles and roles"
    },
    "media": {
      "schema": { "$ref": "#/entities/MediaItem" },
      "description": "Photos and videos shared by users"
    },
    "comments": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on media posts"
    },
    "contacts": {
      "schema": { "$ref": "#/entities/Contact" },
      "description": "Contact relationships between users"
    },
    "chat_groups": {
      "schema": { "$ref": "#/entities/ChatGroup" },
      "description": "Shared chat groups"
    }
  }
}
